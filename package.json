{
  "name": "nimbus-workspace",
  "private": true,
  "workspaces": [
    "nimbus",
    "nimbus/server"
  ],
  "scripts": {
    "dev": "concurrently -n frontend,server -c blue,green \"npm run dev --workspace nimbus\" \"npm run dev --workspace server\"",
    "dev:frontend": "npm run dev --workspace nimbus",
    "dev:server": "npm run dev --workspace server",
    "build": "npm run build --workspace nimbus && npm run build --workspace server",
    "build:frontend": "npm run build --workspace nimbus",
    "build:server": "npm run build --workspace server",
    "start:frontend": "npm run start --workspace nimbus",
    "start:server": "npm run start --workspace server"
  },
  "devDependencies": {
    "concurrently": "^9.0.0"
  }
}